<launch>

  <!-- TurtleBot3 model (burger has 360° LiDAR matching our monitor) -->
  <arg name="model"  default="burger"/>
  <!-- Robot spawn pose: center of grid cell (0,0), facing East (yaw=0) -->
  <arg name="x_pos" default="0.5"/>
  <arg name="y_pos" default="0.5"/>
  <arg name="z_pos" default="0.0"/>

  <!-- Start Gazebo with the maze world -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find dstarlite_maze)/worlds/dstarlite_maze.world"/>
    <arg name="paused"     value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui"        value="true"/>
    <arg name="headless"   value="false"/>
    <arg name="debug"      value="false"/>
  </include>

  <!-- Load TurtleBot3 Burger URDF -->
  <param name="robot_description"
         command="$(find xacro)/xacro $(find turtlebot3_description)/urdf/turtlebot3_$(arg model).urdf.xacro"/>

  <node name="joint_state_publisher" pkg="joint_state_publisher"
        type="joint_state_publisher"/>
  <node name="robot_state_publisher" pkg="robot_state_publisher"
        type="robot_state_publisher"/>

  <!-- Spawn TurtleBot3 into Gazebo -->
  <node name="spawn_urdf" pkg="gazebo_ros" type="spawn_model" output="screen"
        args="-urdf -model turtlebot3_burger
              -x $(arg x_pos) -y $(arg y_pos) -z $(arg z_pos)
              -param robot_description"/>

</launch>
